# ============================================================================
# RWOS (Restaurant WhatsApp Ordering System) - Environment Variables
# ============================================================================

# Meta WhatsApp Business Cloud API
# Get these from https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
VERIFY_TOKEN=YOUR_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_ID
# Kitchen WhatsApp number (where orders will be sent)
# Format: country_code + phone_number (e.g., 919876543210 for India)
KITCHEN_WHATSAPP_NUMBER=KITCHEN_WHATSAPP_NUMBER

# Google Sheets API
# Get this from Google Cloud Console
# Create a service account and download the JSON key file
# Set the entire JSON as a string in this variable, should be in a single line
GOOGLE_CREDENTIALS_JSON=GSJ_HERE

GOOGLE_SHEET_ID=GOOGLE_SHEET_ID_HERE

# Flask
PORT=5000

# Optional: For local development
FLASK_ENV=development
